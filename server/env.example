# Server Configuration
NODE_ENV=development
PORT=5000
HOST=localhost

# Database
MONGODB_URI=mongodb://localhost:27017/ability_v2
REDIS_URL=redis://localhost:6379

# JWT Configuration
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_REFRESH_SECRET=your-super-secret-refresh-key-change-in-production
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# AWS Configuration
AWS_ACCESS_KEY_ID=your-aws-access-key
AWS_SECRET_ACCESS_KEY=your-aws-secret-key
AWS_REGION=us-east-1
AWS_S3_BUCKET=ability-v2-uploads
AWS_SES_FROM_EMAIL=noreply@ability-platform.com

# Twilio Configuration
TWILIO_ACCOUNT_SID=your-twilio-account-sid
TWILIO_AUTH_TOKEN=your-twilio-auth-token
TWILIO_API_KEY=your-twilio-api-key
TWILIO_API_SECRET=your-twilio-api-secret
TWILIO_VIDEO_SERVICE_SID=your-video-service-sid

# Caption Transcription
CAPTION_PROVIDER=openai
OPENAI_API_KEY=your-openai-api-key
OPENAI_TRANSCRIBE_MODEL=gpt-4o-mini-transcribe
OPENAI_CAPTION_CHUNK_MS=2000
OPENAI_CAPTION_MIN_CHUNK_MS=1200
OPENAI_CAPTION_MAX_BUFFER_MS=8000
DEEPGRAM_API_KEY=your-deepgram-api-key

# CORS Configuration
CORS_ORIGIN=http://localhost:3000

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# File Upload Limits
MAX_FILE_SIZE=10485760
ALLOWED_FILE_TYPES=image/jpeg,image/png,image/gif,application/pdf,audio/mpeg,video/mp4

# Sendy Configuration
SENDY_URL=https://sendy.abilityconnect.online
SENDY_API_KEY=your-sendy-api-key
SENDY_BRAND_ID=your-sendy-brand-id
SENDY_LIST_JOB_SEEKERS=uRDga4IRDzP5rA892RHQ1LNg
SENDY_LIST_ANNOUNCEMENTS=yU5fog2SPkMp9YefWmS8gw

# Logging
LOG_LEVEL=info
LOG_FILE=logs/app.log
